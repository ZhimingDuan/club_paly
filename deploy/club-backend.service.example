[Unit]
Description=Club Trae Backend
After=network.target

[Service]
User=ubuntu
WorkingDirectory=/opt/club_trae/backend
EnvironmentFile=/opt/club_trae/backend/.env
ExecStart=/opt/club_trae/backend/.venv/bin/gunicorn main:app -k uvicorn.workers.UvicornWorker -w 2 -b 127.0.0.1:8001
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
